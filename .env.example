# =============================================================================
# Sentinel Gateway — Root Environment Configuration
# Copy to .env and fill in your values for docker-compose
# =============================================================================

# ---------------------------------------------------------------------------
# Database (PostgreSQL 16)
# ---------------------------------------------------------------------------
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel_password
POSTGRES_DB=sentinel_gateway

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
# Set a password for production (leave empty for dev)
REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# Backend Server
# ---------------------------------------------------------------------------
# SaaS mode: single tenant with simplified UI
SAAS_MODE=true

# Log level: trace, debug, info, warn, error
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# License (optional — for Enterprise features)
# ---------------------------------------------------------------------------
# LICENSE_KEY=eyJ...

# ---------------------------------------------------------------------------
# Production only (used by docker-compose.prod.yml)
# ---------------------------------------------------------------------------
# POSTGRES_PASSWORD=<strong-random-password>
# REDIS_PASSWORD=<strong-random-password>
