# =============================================================================
# Sentinel Gateway — Environment Configuration
# Copy to .env and fill in your values
# =============================================================================

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
GATEWAY__SERVER__HOST=0.0.0.0
GATEWAY__SERVER__PORT=8080
GATEWAY__SERVER__SAAS_MODE=false
# GATEWAY__SERVER__DEFAULT_TENANT_SLUG=default

# ---------------------------------------------------------------------------
# Database (PostgreSQL 16)
# ---------------------------------------------------------------------------
GATEWAY__DATABASE__URL=postgres://sentinel:sentinel_password@db:5432/sentinel_gateway
GATEWAY__DATABASE__MAX_CONNECTIONS=20

# ---------------------------------------------------------------------------
# Authentication (RSA-256 keys)
# ---------------------------------------------------------------------------
GATEWAY__AUTH__JWT_PRIVATE_KEY_PATH=keys/private.pem
GATEWAY__AUTH__JWT_PUBLIC_KEY_PATH=keys/public.pem
GATEWAY__AUTH__ACCESS_TOKEN_TTL_MINUTES=15
GATEWAY__AUTH__REFRESH_TOKEN_TTL_DAYS=7
GATEWAY__AUTH__MAX_FAILED_LOGINS=5
GATEWAY__AUTH__LOCKOUT_DURATION_MINUTES=15

# ---------------------------------------------------------------------------
# Telemetry / Observability
# ---------------------------------------------------------------------------
GATEWAY__TELEMETRY__LOG_LEVEL=info
GATEWAY__TELEMETRY__SERVICE_NAME=sentinel-gateway
GATEWAY__TELEMETRY__PROMETHEUS_ENABLED=true
# GATEWAY__TELEMETRY__OTLP_ENDPOINT=http://otel-collector:4317

# ---------------------------------------------------------------------------
# Proxy Engine
# ---------------------------------------------------------------------------
GATEWAY__PROXY__DEFAULT_TIMEOUT_MS=30000
GATEWAY__PROXY__MAX_RETRIES=3
GATEWAY__PROXY__HEALTH_CHECK_INTERVAL_SECS=30
GATEWAY__PROXY__CIRCUIT_BREAKER_THRESHOLD=5
GATEWAY__PROXY__CIRCUIT_BREAKER_RECOVERY_SECS=60

# ---------------------------------------------------------------------------
# License
# ---------------------------------------------------------------------------
# GATEWAY__LICENSE__LICENSE_KEY=eyJ...
# GATEWAY__LICENSE__PUBLIC_KEY_PATH=keys/license_public.pem
GATEWAY__LICENSE__GRACE_PERIOD_DAYS=7

# ---------------------------------------------------------------------------
# Redis (optional — for distributed rate limiting)
# ---------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Encryption (field-level encryption for backend credentials)
# ---------------------------------------------------------------------------
# 32-byte hex key for ChaCha20-Poly1305 encryption at rest
# Generate with: openssl rand -hex 32
# GATEWAY__SERVER__ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# ---------------------------------------------------------------------------
# Allow all origins (default true for local development)
GATEWAY__SERVER__CORS_ALLOW_ALL=true
# Restrict to specific origins in production (comma-separated in env, array in config)
# GATEWAY__SERVER__CORS_ORIGINS=https://gateway.example.com,https://admin.example.com

# ---------------------------------------------------------------------------
# TLS Enforcement (reject plaintext HTTP)
# ---------------------------------------------------------------------------
# Reject plaintext HTTP with 426 Upgrade Required. Trusts X-Forwarded-Proto
# from your load balancer/reverse proxy. Enable for production.
GATEWAY__SERVER__REQUIRE_TLS=false
GATEWAY__SERVER__TRUST_FORWARDED_PROTO=true

# ---------------------------------------------------------------------------
# Database: Auto-migration + query observability
# ---------------------------------------------------------------------------
# Auto-run migrations on startup (uses pg_advisory_lock for multi-replica safety).
# Production: set to false and run `gateway-server migrate` as a separate job.
GATEWAY__DATABASE__AUTO_MIGRATE=true
# Enable pg_stat_statements extension + /admin/slow-queries endpoint (requires superuser)
GATEWAY__DATABASE__ENABLE_QUERY_STATS=false
# Log all SQL queries at DEBUG; slow queries (>200ms) always logged at WARN
GATEWAY__DATABASE__LOG_QUERIES=false

# ---------------------------------------------------------------------------
# Multi-replica deployment
# ---------------------------------------------------------------------------
# Number of replicas. When >1, Redis is required for rate limiter consistency.
GATEWAY__REPLICAS=1

# ---------------------------------------------------------------------------
# Observability Export (optional)
# ---------------------------------------------------------------------------
# Forward LLM traces to external observability platforms. Opt-in — no data
# leaves the gateway unless you explicitly configure one of these.
#
# Langfuse (https://langfuse.com)
# GATEWAY__OBSERVABILITY__LANGFUSE__BASE_URL=https://cloud.langfuse.com
# GATEWAY__OBSERVABILITY__LANGFUSE__PUBLIC_KEY=pk-lf-...
# GATEWAY__OBSERVABILITY__LANGFUSE__SECRET_KEY=sk-lf-...
#
# Helicone (https://helicone.ai)
# GATEWAY__OBSERVABILITY__HELICONE__BASE_URL=https://api.helicone.ai
# GATEWAY__OBSERVABILITY__HELICONE__API_KEY=sk-helicone-...
#
# Max queued events before drops (export is fire-and-forget)
# GATEWAY__OBSERVABILITY__QUEUE_SIZE=1000
